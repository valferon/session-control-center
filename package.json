{
  "name": "session-control-center",
  "displayName": "Session Control Center for Claude Code",
  "description": "Unofficial control center for local Claude Code sessions across all your repos: live sidebar, searchable dashboard, one-click context switch. Not affiliated with Anthropic.",
  "version": "0.1.4",
  "publisher": "valferon",
  "license": "MIT",
  "icon": "icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/valferon/session-control-center.git"
  },
  "bugs": {
    "url": "https://github.com/valferon/session-control-center/issues"
  },
  "homepage": "https://github.com/valferon/session-control-center#readme",
  "keywords": [
    "claude code",
    "agent",
    "sessions",
    "dashboard",
    "productivity"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onView:claudeControlCenter.sessions",
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeCC",
          "title": "Claude Control Center",
          "icon": "icons/activity.svg"
        }
      ]
    },
    "views": {
      "claudeCC": [
        {
          "id": "claudeControlCenter.sessions",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeControlCenter.openDashboard",
        "title": "Claude Control Center: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "claudeControlCenter.refresh",
        "title": "Claude Control Center: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeControlCenter.search",
        "title": "Claude Control Center: Search Sessions",
        "icon": "$(search)"
      },
      {
        "command": "claudeControlCenter.filterStatus",
        "title": "Claude Control Center: Filter by Status",
        "icon": "$(filter)"
      },
      {
        "command": "claudeControlCenter.markAllReviewed",
        "title": "Claude Control Center: Mark All as Read",
        "icon": "$(check-all)"
      },
      {
        "command": "claudeControlCenter.toggleHideIdle",
        "title": "Claude Control Center: Toggle Hide Idle",
        "icon": "$(eye)"
      },
      {
        "command": "claudeControlCenter.clearFilters",
        "title": "Claude Control Center: Clear Filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "claudeControlCenter.toggleShowArchived",
        "title": "Claude Control Center: Toggle Show Archived",
        "icon": "$(archive)"
      },
      {
        "command": "claudeControlCenter.archiveSession",
        "title": "Archive Session",
        "icon": "$(archive)"
      },
      {
        "command": "claudeControlCenter.unarchiveSession",
        "title": "Unarchive Session",
        "icon": "$(history)"
      },
      {
        "command": "claudeControlCenter.openSession",
        "title": "Open Session",
        "icon": "$(arrow-right)"
      },
      {
        "command": "claudeControlCenter.newSessionInProject",
        "title": "New Claude Session in Project",
        "icon": "$(add)"
      },
      {
        "command": "claudeControlCenter.openSessionFolderNewWindow",
        "title": "Open Repo in New Window",
        "icon": "$(empty-window)"
      },
      {
        "command": "claudeControlCenter.openSessionFolderHere",
        "title": "Open Repo in This Window"
      },
      {
        "command": "claudeControlCenter.newConversationHere",
        "title": "Start Claude Here",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "claudeControlCenter.copySessionId",
        "title": "Copy Session ID"
      },
      {
        "command": "claudeControlCenter.deleteSession",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "claudeControlCenter.showLogs",
        "title": "Claude Control Center: Show Logs",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeControlCenter.search",
          "when": "view == claudeControlCenter.sessions",
          "group": "navigation@1"
        },
        {
          "command": "claudeControlCenter.filterStatus",
          "when": "view == claudeControlCenter.sessions",
          "group": "navigation@2"
        },
        {
          "command": "claudeControlCenter.markAllReviewed",
          "when": "view == claudeControlCenter.sessions",
          "group": "navigation@3"
        },
        {
          "command": "claudeControlCenter.toggleHideIdle",
          "when": "view == claudeControlCenter.sessions",
          "group": "navigation@3"
        },
        {
          "command": "claudeControlCenter.openDashboard",
          "when": "view == claudeControlCenter.sessions",
          "group": "navigation@4"
        },
        {
          "command": "claudeControlCenter.refresh",
          "when": "view == claudeControlCenter.sessions",
          "group": "navigation@5"
        },
        {
          "command": "claudeControlCenter.toggleShowArchived",
          "when": "view == claudeControlCenter.sessions",
          "group": "overflow@1"
        },
        {
          "command": "claudeControlCenter.clearFilters",
          "when": "view == claudeControlCenter.sessions",
          "group": "overflow@2"
        },
        {
          "command": "claudeControlCenter.showLogs",
          "when": "view == claudeControlCenter.sessions",
          "group": "overflow@3"
        }
      ],
      "view/item/context": [
        {
          "command": "claudeControlCenter.newSessionInProject",
          "when": "view == claudeControlCenter.sessions && viewItem == ccProject",
          "group": "inline@1"
        },
        {
          "command": "claudeControlCenter.openSessionFolderNewWindow",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session/",
          "group": "inline@1"
        },
        {
          "command": "claudeControlCenter.newConversationHere",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session/",
          "group": "inline@2"
        },
        {
          "command": "claudeControlCenter.archiveSession",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session(?:(?!archived).)*$/",
          "group": "inline@3"
        },
        {
          "command": "claudeControlCenter.unarchiveSession",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /archived/",
          "group": "inline@3"
        },
        {
          "command": "claudeControlCenter.deleteSession",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session/",
          "group": "inline@4"
        },
        {
          "command": "claudeControlCenter.openSessionFolderHere",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session/",
          "group": "navigation@1"
        },
        {
          "command": "claudeControlCenter.copySessionId",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session/",
          "group": "navigation@2"
        },
        {
          "command": "claudeControlCenter.archiveSession",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session(?:(?!archived).)*$/",
          "group": "archive@1"
        },
        {
          "command": "claudeControlCenter.unarchiveSession",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /archived/",
          "group": "archive@1"
        },
        {
          "command": "claudeControlCenter.deleteSession",
          "when": "view == claudeControlCenter.sessions && viewItem =~ /^session/",
          "group": "danger@1"
        }
      ]
    },
    "configuration": {
      "title": "Claude Control Center",
      "properties": {
        "claudeControlCenter.activeThresholdMinutes": {
          "type": "number",
          "default": 5,
          "description": "A session whose log changed within this many minutes is shown as Active."
        },
        "claudeControlCenter.idleThresholdHours": {
          "type": "number",
          "default": 24,
          "description": "A session not Active but touched within this many hours is shown as Finished; older than this is Idle (stale, hidden by default)."
        },
        "claudeControlCenter.projectsDir": {
          "type": "string",
          "default": "",
          "description": "Override path to the Claude projects dir. Empty = auto-detect ($CLAUDE_CONFIG_DIR/projects or ~/.claude/projects)."
        },
        "claudeControlCenter.openFolderMode": {
          "type": "string",
          "enum": [
            "newWindow",
            "prompt",
            "currentWindow"
          ],
          "default": "newWindow",
          "description": "How clicking a session opens its repo. newWindow keeps the control center alive."
        },
        "claudeControlCenter.sidebarHideIdle": {
          "type": "boolean",
          "default": true,
          "description": "Hide idle (stale, older than the idle threshold) sessions in the sidebar tree by default (cuts noise). Toggle live from the view title bar."
        },
        "claudeControlCenter.sidebarTitleMaxLength": {
          "type": "number",
          "default": 40,
          "minimum": 0,
          "description": "Max characters of a session title shown in the sidebar before it is truncated with an ellipsis. 0 disables truncation (show full title)."
        },
        "claudeControlCenter.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log per-session status decisions (age, last role, stop_reason, thresholds) to the 'Claude Control Center' output channel on every refresh. Status transitions are always logged; this adds the full per-refresh dump. Turn on to investigate a session shown with the wrong status, then run 'Show Logs'."
        },
        "claudeControlCenter.openOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Reveal the view automatically when the editor starts."
        },
        "claudeControlCenter.usage.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show Claude subscription usage (5h/weekly windows) in the sidebar. Off by default: when on, this reads your local Claude OAuth token from ~/.claude/.credentials.json and calls Anthropic's usage endpoint with it. The token is only sent to api.anthropic.com as an auth header, never logged or stored. Leave off if you'd rather the extension make no network calls."
        },
        "claudeControlCenter.notifications.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Master switch for desktop notifications about session activity."
        },
        "claudeControlCenter.notifications.onFinish": {
          "type": "boolean",
          "default": true,
          "description": "Notify when a session goes from active to idle (an agent likely finished a piece of work / is waiting on you)."
        },
        "claudeControlCenter.notifications.onPr": {
          "type": "boolean",
          "default": true,
          "description": "Notify when a session links a new pull request."
        },
        "claudeControlCenter.notifications.maxAgeMinutes": {
          "type": "number",
          "default": 120,
          "description": "Only notify about PR links for sessions active within this many minutes. Prevents old sessions from firing stale notifications."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --production && vsce package --no-dependencies",
    "publish:ovsx": "node esbuild.mjs --production && ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.6.0"
  }
}
